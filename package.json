{
  "name": "sous-chef",
  "version": "1.0.0",
  "description": "Local-first recipe and grocery management application",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "install:all": "npm install && cd pwa && npm install",
    "start": "cd pwa && npm run dev",
    "build": "tsc && cd pwa && npm run build",
    "build:lib": "tsc",
    "build:app": "cd pwa && npm run build",
    "preview": "cd pwa && npm run preview",
    "dev": "cd pwa && npm run dev",
    "test": "vitest run && cd pwa && npm run test",
    "test:lib": "vitest run",
    "test:app": "cd pwa && npm run test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lhci": "npm run build:app && cd pwa && npm run lhci",
    "generate-fixtures": "tsx scripts/generate-url-fixtures.ts",
    "inspect-db": "tsx scripts/inspect-db.ts"
  },
  "keywords": [
    "recipe",
    "cooking",
    "meal-planning",
    "grocery",
    "local-first"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.6.1",
    "better-sqlite3": "^12.8.0",
    "eslint": "^8.55.0",
    "fast-check": "^3.14.0",
    "prettier": "^3.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "sql.js": "^1.9.0",
    "uuid": "^9.0.1"
  }
}
